{
  "name": "chatgpt2api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint . && stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "vue-tsc --noEmit",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.39",
    "vue-i18n": "11.1.12",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.28.1",
    "husky": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "postcss-html": "^1.8.1",
    "stylelint": "latest",
    "stylelint-config-standard": "latest",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,json,md}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.{css,vue}": [
      "stylelint --fix --allow-empty-input"
    ],
    "src-tauri/src/**/*.rs": [
      "bash -c 'cargo fmt --manifest-path src-tauri/Cargo.toml'"
    ]
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "esbuild",
    "vue-demi"
  ]
}
