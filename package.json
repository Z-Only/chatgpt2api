{
  "name": "chatgpt2api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint . && stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "vue-tsc --noEmit",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@vitejs/plugin-vue": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "stylelint": "latest",
    "stylelint-config-standard": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "vue-tsc": "latest"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,json,css,md}": [
      "oxfmt --write",
      "oxlint --fix",
      "stylelint --fix --allow-empty-input"
    ],
    "src-tauri/src/**/*.rs": [
      "cargo fmt --manifest-path src-tauri/Cargo.toml"
    ]
  }
}
