{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ChatGPT2API",
  "version": "0.1.0",
  "identifier": "dev.chatgpt2api.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "ChatGPT2API",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": false,
    "publisher": "ChatGPT2API Contributors",
    "category": "DeveloperTool",
    "shortDescription": "Local OpenAI-compatible API bridge for ChatGPT/Codex",
    "longDescription": "ChatGPT2API turns a ChatGPT subscription into a local OpenAI-compatible API with a desktop control surface and CLI.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
